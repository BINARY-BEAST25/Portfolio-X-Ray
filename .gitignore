# ─── Root .gitignore ──────────────────────────────────────────────────────────

# Environment variables (NEVER commit real secrets)
.env
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local

# Node modules
node_modules/
*/node_modules/

# Build outputs
frontend/dist/
frontend/.vite/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Vercel
.vercel/
