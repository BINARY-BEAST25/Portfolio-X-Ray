# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio_xray?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret_string_minimum_32_chars
JWT_EXPIRE=7d

# ─── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ─── mfapi.in (free mutual fund data – no key needed) ─────────────────────────
MFAPI_BASE_URL=https://api.mfapi.in/mf

# ─── Frontend URL (for CORS whitelist) ────────────────────────────────────────
# On Vercel this will be your deployed frontend URL e.g. https://portfolio-x-ray.vercel.app
CLIENT_URL=https://your-frontend-url.vercel.app
